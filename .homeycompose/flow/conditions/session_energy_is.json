{
  "id": "session_energy_is",
  "title": {
    "en": "Session energy comparison",
    "nl": "Sessie-energie vergelijking"
  },
  "titleFormatted": {
    "en": "Session energy !{{is|is not}} [[operator]] [[value]] kWh",
    "nl": "Sessie-energie !{{is|is niet}} [[operator]] [[value]] kWh"
  },
  "hint": {
    "en": "Checks if the current session energy matches the condition.",
    "nl": "Controleert of de huidige sessie-energie voldoet aan de voorwaarde."
  },
  "args": [
    {
      "type": "device",
      "name": "device",
      "filter": "driver_id=source2s"
    },
    {
      "type": "dropdown",
      "name": "operator",
      "title": {
        "en": "Operator",
        "nl": "Operator"
      },
      "values": [
        { "id": "lt", "label": { "en": "Less than", "nl": "Kleiner dan" } },
        { "id": "lte", "label": { "en": "Less than or equal", "nl": "Kleiner dan of gelijk aan" } },
        { "id": "gt", "label": { "en": "Greater than", "nl": "Groter dan" } },
        { "id": "gte", "label": { "en": "Greater than or equal", "nl": "Groter dan of gelijk aan" } }
      ]
    },
    {
      "type": "number",
      "name": "value",
      "title": {
        "en": "Value",
        "nl": "Waarde"
      },
      "min": 0,
      "step": 0.1
    }
  ]
}
