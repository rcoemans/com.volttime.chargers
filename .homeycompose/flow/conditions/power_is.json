{
  "id": "power_is",
  "title": {
    "en": "Power comparison",
    "nl": "Vermogen vergelijking"
  },
  "titleFormatted": {
    "en": "Power !{{is|is not}} [[operator]] [[value]] W",
    "nl": "Vermogen !{{is|is niet}} [[operator]] [[value]] W"
  },
  "hint": {
    "en": "Checks if the current charging power matches the condition.",
    "nl": "Controleert of het huidige laadvermogen voldoet aan de voorwaarde."
  },
  "args": [
    {
      "type": "device",
      "name": "device",
      "filter": "driver_id=source2s"
    },
    {
      "type": "dropdown",
      "name": "operator",
      "title": {
        "en": "Operator",
        "nl": "Operator"
      },
      "values": [
        { "id": "lt", "label": { "en": "Less than", "nl": "Kleiner dan" } },
        { "id": "lte", "label": { "en": "Less than or equal", "nl": "Kleiner dan of gelijk aan" } },
        { "id": "gt", "label": { "en": "Greater than", "nl": "Groter dan" } },
        { "id": "gte", "label": { "en": "Greater than or equal", "nl": "Groter dan of gelijk aan" } }
      ]
    },
    {
      "type": "number",
      "name": "value",
      "title": {
        "en": "Value",
        "nl": "Waarde"
      },
      "min": 0,
      "step": 100
    }
  ]
}
